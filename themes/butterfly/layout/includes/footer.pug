-
  var footerConfig = theme.footer || {}
  var nav = footerConfig.nav || false
  var owner = footerConfig.owner || {}
  var copyright = footerConfig.copyright || {}
  var custom_text = footerConfig.custom_text || ''
  var currentYear = new Date().getFullYear()
  var siteBuildDate = footerConfig.build_date || '2026-04-24'
  var runtimeStart = footerConfig.runtime_start || (siteBuildDate + 'T00:00:00+08:00')
  var icpConfig = footerConfig.icp || {}
  var icpNumber = icpConfig.text || '萌ICP备20268010号'
  var icpUrl = icpConfig.url || 'https://icp.gov.moe/?keyword=20268010'
  var socialEntries = Object.entries(theme.social || {})
  var footerGroups = footerConfig.link_groups || [
    { title: '内容', links: [{ text: '文章归档', url: '/archives/' }, { text: '分类索引', url: '/categories/' }, { text: '标签云', url: '/tags/' }, { text: '随机阅读', url: '/random.html' }] },
    { title: '站点', links: [{ text: '首页', url: '/' }, { text: '关于本站', url: '/about/' }, { text: '资源导航', url: '/sites/' }, { text: '实用工具', url: '/tools/' }] },
    { title: '项目', links: [{ text: '下载中心', url: '/downloads/' }, { text: '留言板', url: '/guestbook/' }, { text: 'GitHub 主页', url: 'https://github.com/szy321123' }] },
    { title: '联系', links: [{ text: 'GitHub', url: 'https://github.com/szy321123' }, { text: 'Email', url: 'mailto:szy007700@qq.com' }, { text: 'Telegram', url: 'https://t.me/boluo12334' }] },
    { title: '协议', links: [{ text: '隐私协议', url: '/privacy/' }, { text: '版权协议', url: '/copyright/' }, { text: 'CC BY-NC-SA 4.0', url: 'https://creativecommons.org/licenses/by-nc-sa/4.0/' }] }
  ]

if nav
  .footer-flex
    each block in nav
      .footer-flex-items(style=`${ block.width ? 'flex-grow:' + block.width : '' }`)
        each blockItem in block.content
          .footer-flex-item
            .footer-flex-title= blockItem.title
            .footer-flex-content
              each subitem in blockItem.item
                if subitem.html
                  div!= subitem.html
                else if subitem.url
                  a(href=url_for(subitem.url), target='_blank', title=subitem.title)= subitem.title
                else if subitem.title
                  div!= subitem.title

.footer-other
  .footer-enhance
    if socialEntries.length
      .footer-social-row
        each item in socialEntries
          - var rawValue = String(item[1] || '')
          - var parts = rawValue.split('||')
          - var socialUrl = (parts[0] || '').trim()
          - var socialName = (parts[1] || '').trim()
          - var socialColor = (parts[2] || '').trim().replace(/^['"]|['"]$/g, '')
          - var socialExternal = /^(https?:|mailto:|\/\/)/.test(socialUrl)
          if socialUrl
            if socialExternal
              a.footer-social-btn(href=socialUrl, target='_blank', rel='noopener', title=(socialName || item[0]))
                i(class=item[0], style=(socialColor ? 'color:' + socialColor : ''))
            else
              a.footer-social-btn(href=url_for(socialUrl), title=(socialName || item[0]))
                i(class=item[0], style=(socialColor ? 'color:' + socialColor : ''))

    .footer-link-grid
      each group in footerGroups
        .footer-link-group
          .footer-link-title= group.title
          .footer-link-list
            each sub in group.links
              - var external = /^(https?:|mailto:|\/\/)/.test(sub.url)
              if external
                a.footer-link-item(href=sub.url, target='_blank', rel='noopener', title=sub.text)= sub.text
              else
                a.footer-link-item(href=url_for(sub.url), title=sub.text)= sub.text

  .footer-runtime-row
    .footer-runtime
      span.runtime-label 小破站已稳定运行
      span#site-runtime.runtime-value(data-start=runtimeStart) 0天 00:00:00

  .footer-copyright
    if owner.enable
      - var sinceYear = owner.since
      span.copyright
        if sinceYear && sinceYear != currentYear
          != '&copy;&nbsp;' + sinceYear + ' - ' + currentYear + ' By ' + config.author
        else
          != '&copy;&nbsp;' + currentYear + ' By ' + config.author

    span.icp-info
      if owner.enable
        span.footer-separator |
      a(href=icpUrl, target='_blank', rel='noopener', title='备案查询')= icpNumber

  if custom_text
    .footer_custom_text!= custom_text

script.
  (function () {
    function initFooterRuntime() {
      var runtimeEl = document.getElementById('site-runtime')
      if (!runtimeEl) return

      var startMs = Date.parse(runtimeEl.getAttribute('data-start') || '')
      if (Number.isNaN(startMs)) {
        runtimeEl.textContent = '时间配置错误'
        return
      }

      var pad = function (num) {
        return String(num).padStart(2, '0')
      }

      var update = function () {
        var deltaSeconds = Math.max(0, Math.floor((Date.now() - startMs) / 1000))
        var days = Math.floor(deltaSeconds / 86400)
        var hours = Math.floor((deltaSeconds % 86400) / 3600)
        var minutes = Math.floor((deltaSeconds % 3600) / 60)
        var seconds = deltaSeconds % 60
        runtimeEl.textContent = days + '天 ' + pad(hours) + ':' + pad(minutes) + ':' + pad(seconds)
      }

      update()
      if (window.__zyRuntimeTimer) clearInterval(window.__zyRuntimeTimer)
      window.__zyRuntimeTimer = setInterval(update, 1000)
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initFooterRuntime, { once: true })
    } else {
      initFooterRuntime()
    }

    document.addEventListener('pjax:complete', initFooterRuntime)
  })()
