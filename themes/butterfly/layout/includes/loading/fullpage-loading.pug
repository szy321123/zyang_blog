#loading-box
  .loading-left-bg
  .loading-right-bg
  .spinner-box
    .preloader-scene
      #preloader-lottie.preloader-lottie

script.
  (()=>{
    const $loadingBox = document.getElementById('loading-box')
    const $body = document.body
    const $lottieContainer = document.getElementById('preloader-lottie')
    const pjaxEnabled = !{theme.pjax && theme.pjax.enable ? 'true' : 'false'}
    const minDuration = 1200
    let startTime = Date.now()
    let lottieInstance = null
    let lottieLoaderPromise = null

    const ensureLottie = () => {
      if (!$lottieContainer || lottieInstance) return
      if (!lottieLoaderPromise) {
        lottieLoaderPromise = new Promise(resolve => {
          if (window.lottie && typeof window.lottie.loadAnimation === 'function') {
            resolve(window.lottie)
            return
          }
          const script = document.createElement('script')
          script.src = 'https://cdn.jsdelivr.net/npm/lottie-web@5.12.2/build/player/lottie.min.js'
          script.async = true
          script.onload = () => resolve(window.lottie || null)
          script.onerror = () => resolve(null)
          document.head.appendChild(script)
        })
      }

      lottieLoaderPromise.then(lottieLib => {
        if (!lottieLib || lottieInstance || !$lottieContainer) return
        lottieInstance = lottieLib.loadAnimation({
          container: $lottieContainer,
          renderer: 'svg',
          loop: true,
          autoplay: true,
          path: '/json/running-cat.json'
        })
      })
    }

    const preloader = {
      endLoading: () => {
        if ($loadingBox.classList.contains('loaded')) return
        const elapsed = Date.now() - startTime
        const finish = () => {
          if ($loadingBox.classList.contains('loaded')) return
          $body.style.overflow = ''
          $loadingBox.classList.add('loaded')
        }
        if (elapsed >= minDuration) {
          finish()
        } else {
          setTimeout(finish, minDuration - elapsed)
        }
      },
      initLoading: () => {
        startTime = Date.now()
        $body.style.overflow = 'hidden'
        $loadingBox.classList.remove('loaded')
        ensureLottie()
      }
    }

    ensureLottie()
    preloader.initLoading()

    if (document.readyState === 'complete') {
      preloader.endLoading()
    } else {
      window.addEventListener('load', preloader.endLoading)
      document.addEventListener('DOMContentLoaded', preloader.endLoading)
      // Add timeout protection: force end after 7 seconds
      setTimeout(preloader.endLoading, 7000)
    }

    if (pjaxEnabled && window.btf && typeof window.btf.addGlobalFn === 'function') {
      btf.addGlobalFn('pjaxSend', preloader.initLoading, 'preloader_init')
      btf.addGlobalFn('pjaxComplete', preloader.endLoading, 'preloader_end')
    }
  })()
